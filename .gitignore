# Runtime directories - contents ignored but directories kept for structure
# Input/ - user dialogue source files (keep .txt samples, ignore runtime)
Input/test/
Input/**/*.pkl
Input/**/*.json
Input/**/*.diff
Input/**/*.log
Input/**/*.flac
Input/**/*.wav
!Input/test/.gitkeep

# Output/ - rendered audio and cache (all runtime-generated)
Output/**/*.flac
Output/**/*.wav
Output/**/*.pkl
Output/**/*.json
Output/**/*.diff
Output/**/*.log

# Profiles/ - voice profiles (runtime-generated)
Profiles/**/*.json

# Seashells/ - curated voice references (keep .wav, ignore cache)
Seashells/.oracle_preview/
Seashells/**/*.pkl

# user_settings/ - GUI settings (runtime-generated)
user_settings/**/*.json

# release_artifacts/ - build outputs (generated by release script)
release_artifacts/**/*.tar.gz
release_artifacts/**/*.sha256
release_artifacts/**/*.json
